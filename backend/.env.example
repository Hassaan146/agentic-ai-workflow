# Backend local/deployment example
APP_ENV=dev
ALLOW_DEV_AUTH=true
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Use duckduckgo for live public search + page scraping. Use mock for offline tests.
SEARCH_PROVIDER=duckduckgo

# Groq keys. Put real keys in backend/.env only, never in this example file.
GROQ_API_KEY=your_fast_groq_api_key
GROQ_REASONING_API_KEY=your_reasoning_groq_api_key
GOOGLE_API_KEY=
JWT_SECRET=your_long_random_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

DEFAULT_FAST_MODEL=llama-3.1-8b-instant
DEFAULT_REASONING_MODEL=llama-3.3-70b-versatile

# Production-only later
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
